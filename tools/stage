#!/usr/bin/env bash
# tools/stage — staging-environment helper. Wraps the docker-compose
# invocations + smoke-test integration so the operator runs one
# command instead of remembering --env-file, -f, -p, and which
# hostname overrides each subcommand needs.
#
# See docs/staging_environment.md for the surrounding architecture.
#
# Usage: tools/stage <subcommand> [args]
#
# Subcommands:
#   up                   Bring up the staging stack
#   down                 Stop and remove staging containers (volumes preserved)
#   bash [service]       Shell into a staging container (default: stra2us-iot-staging)
#   logs [service]       Tail logs (default: all services)
#   status               Show staging container states
#   wait-tunnel          Poll cloudflared logs until 4 connections register
#   smoke                Run smoke test against staging hostnames.
#                        Also runs the device-flow smoke (Sprint 6,
#                        v1.7.2) unless --skip-device-flow is passed.
#   smoke-device         Run only the device-flow smoke (HMAC-signed
#                        POST/PUT/GET against /q/ and /kv/ via
#                        `stra2us synth-traffic`). Provisions the
#                        smoke-test device automatically on first run.
#   smoke-prod           Run smoke test against prod hostnames
#                        (sources $PROD_DIR/.env from .deploy-config)
#   seed-users [--force] Provision the smoke + admin + OAuth seed users
#                        Idempotent: skips users already in htpasswd + Redis.
#                        --force re-provisions regardless of existing state.
#   seed-smoke-device    Provision the device-flow smoke HMAC client
#   [--force]            (`smoke-test-device`) on staging Redis with the
#                        `_smoke/<id>:rw` + `_smoke/public:rw` ACL.
#                        Idempotent: reuses an existing secret unless
#                        --force regenerates. Invoked transitively by
#                        `tools/stage smoke` on first run.
#   deploy [ref]         git pull (or checkout <ref>), rebuild image,
#                        restart stack, wait for tunnel.
#                        For a branch never checked out locally on the
#                        staging host, pass the fully-qualified remote
#                        ref (e.g. `origin/my-branch`) — git's `-B`
#                        won't auto-DWIM a bare branch name.
#   promote <tag>        Promote prod to <tag>: fetch tags in $PROD_DIR,
#                        checkout -B deploy <tag>, rebuild + restart
#                        prod stack, wait for tunnel. Tag must already
#                        exist on origin.
#   help                 Print this message

set -u

# Resolve repo root regardless of where the script is invoked from.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_ROOT"

STAGING_COMPOSE="docker-compose.staging.yaml"
STAGING_ENV_FILE=".env.staging"
STAGING_PROJECT="stra2us-staging"
STAGING_BACKEND_SERVICE="stra2us-iot-staging"
STAGING_TUNNEL_SERVICE="cloudflared-staging"

# Hostnames the smoke test should target on staging. Per
# docs/staging_environment.md.
STAGING_BROWSER_HOST="stra2us-staging.austindavid.com"
STAGING_DEVICE_HOST="iot-staging.stra2us.austindavid.com"
STAGING_DEVICE_PORT="8253"

# v1.7.2 Sprint 6: device-flow smoke test. Stable identifiers so the
# secret stays put across runs (operators see a single recurring entry
# in the activity log for the smoke probe — useful for "is this test
# still running?" triage). The leading underscore on the app name
# signals "internal" so operators don't confuse it with a real
# customer-facing app in the admin UI.
SMOKE_DEVICE_CLIENT_ID="smoke-test-device"
SMOKE_DEVICE_APP="_smoke"

# --- helpers ---------------------------------------------------------

err() { printf "stage: %s\n" "$*" >&2; }
die() { err "$*"; exit 1; }

# Wrapper for docker compose against the staging stack — captures all
# the flags that would otherwise be retyped.
dcs() {
    docker compose \
        --env-file "$STAGING_ENV_FILE" \
        -f "$STAGING_COMPOSE" \
        -p "$STAGING_PROJECT" \
        "$@"
}

require_env_file() {
    [[ -f "$STAGING_ENV_FILE" ]] || die "$STAGING_ENV_FILE missing — see docs/staging_environment.md sub-task 3d"
}

# v1.7.1 Sprint 2: write the running-release tag to backend/VERSION
# inside <target-dir>'s repo clone. Backend's core/version.py reads
# this file at startup; the admin sidebar fetches it via
# /api/admin/release and renders in the footer. Format:
# "<ref> (<short-sha>)" — both pieces so the badge distinguishes a
# clean-tagged deploy from an in-flight mid-cycle commit.
#
# Idempotent: called from cmd_deploy (staging) and cmd_promote
# (prod) after their respective `git checkout` step. The file
# lives at <target-dir>/backend/VERSION; the container bind-mounts
# ./backend → /app so the new content is visible after the next
# `docker compose up -d` (which both callers run).
#
# `<target-dir>` defaults to the current repo for cmd_deploy
# (running locally) or $PROD_DIR for cmd_promote.
_write_version_file() {
    local ref="$1"
    local target_dir="${2:-.}"
    local short_sha
    short_sha=$(git -C "$target_dir" rev-parse --short HEAD)
    local version_file="$target_dir/backend/VERSION"
    printf "%s (%s)\n" "$ref" "$short_sha" > "$version_file"
    echo "→ wrote $version_file: $ref ($short_sha)"
}

# True if the username has an entry in the host-side admin.htpasswd.
htpasswd_has_user() {
    local user="$1"
    grep -q "^${user}:" "$REPO_ROOT/backend/admin.htpasswd" 2>/dev/null
}

# True if `admin_acls:<user>` exists in the staging Redis.
redis_has_acl() {
    local user="$1"
    local v
    v=$(dcs exec -T "$STAGING_BACKEND_SERVICE" redis-cli EXISTS "admin_acls:$user" 2>/dev/null | tr -d '\r\n')
    [[ "$v" == "1" ]]
}

# v1.7.2 Sprint 6 helpers.
#
# Print the smoke device's existing secret, or empty string if the
# client hasn't been provisioned yet. Used to decide whether
# `seed-smoke-device` is a no-op and to fetch the secret for
# `smoke-device` to pass to the CLI.
_redis_smoke_device_secret() {
    dcs exec -T "$STAGING_BACKEND_SERVICE" redis-cli \
        GET "client:${SMOKE_DEVICE_CLIENT_ID}:secret" 2>/dev/null \
        | tr -d '\r\n'
}

# Mint a 32-byte hex secret (matches backend/src/core/security.py).
# Using python3 from the host (not the container) keeps this fast and
# avoids a needless `dcs exec` round-trip for what's a 1-liner.
_mint_secret_hex() {
    python3 -c 'import secrets; print(secrets.token_hex(32))'
}

# Idempotently ensure the smoke-test HMAC client exists with the
# device-on-app ACL shape (matches `provision_device` in
# routes_admin.py). Honors `$force` from the caller's scope: 1 →
# regenerate the secret; 0 → reuse the existing one if any.
#
# ACL: rw on `_smoke/smoke-test-device` (the device's own namespace)
# + rw on `_smoke/public` (the shared topic the synth-traffic queue
# writes target). Wholesale-replaces whatever ACL was there before —
# safe because no other code provisions this client_id.
#
# Prints the secret hex to stdout on success so the caller can stash
# it. Stderr gets human-readable progress.
_ensure_smoke_device() {
    local force="${1:-0}"
    local existing
    existing=$(_redis_smoke_device_secret)

    local secret
    if [[ -n "$existing" && "$force" != "1" ]]; then
        secret="$existing"
        echo "  ✓ smoke device already provisioned; reusing existing secret" >&2
    else
        secret=$(_mint_secret_hex)
        dcs exec -T "$STAGING_BACKEND_SERVICE" redis-cli \
            SET "client:${SMOKE_DEVICE_CLIENT_ID}:secret" "$secret" >/dev/null
        if [[ -n "$existing" ]]; then
            echo "  ✓ smoke device secret regenerated (--force)" >&2
        else
            echo "  ✓ smoke device secret minted" >&2
        fi
    fi

    # ACL always replaced — cheap and safer than diffing JSON. Format
    # matches the provision_device endpoint's output exactly so an
    # operator could equivalently re-provision via the admin UI.
    local acl
    acl="{\"permissions\":[{\"prefix\":\"${SMOKE_DEVICE_APP}/${SMOKE_DEVICE_CLIENT_ID}\",\"access\":\"rw\"},{\"prefix\":\"${SMOKE_DEVICE_APP}/public\",\"access\":\"rw\"}]}"
    dcs exec -T "$STAGING_BACKEND_SERVICE" redis-cli \
        SET "client:${SMOKE_DEVICE_CLIENT_ID}:acl" "$acl" >/dev/null
    echo "  ✓ smoke device ACL set: ${SMOKE_DEVICE_APP}/${SMOKE_DEVICE_CLIENT_ID}:rw + ${SMOKE_DEVICE_APP}/public:rw" >&2

    printf "%s" "$secret"
}

# --- subcommands -----------------------------------------------------

cmd_help() {
    # Print the header comment block (every leading-# line after the
    # shebang, stripped of the `# ` prefix). Self-maintaining — adding
    # a new subcommand to the header docs above shows up in `help`
    # automatically, no line-range to update.
    awk 'NR==1 {next} /^[^#]/ {exit} {sub(/^# ?/, ""); print}' "$0"
}

cmd_up() {
    require_env_file
    echo "→ docker compose up -d (staging)"
    dcs up -d --build
    echo
    echo "Stack started. Wait for tunnel readiness with: tools/stage wait-tunnel"
}

cmd_down() {
    echo "→ docker compose down (staging) — volumes preserved"
    dcs down
}

cmd_bash() {
    local service="${1:-$STAGING_BACKEND_SERVICE}"
    dcs exec "$service" bash
}

cmd_logs() {
    # Default: follow (live tail). Pass --no-follow as the first arg
    # for a one-shot read of the recent buffer (useful with grep).
    local follow_flag="-f"
    if [[ "${1:-}" == "--no-follow" ]]; then
        follow_flag=""
        shift
    fi
    if [[ $# -gt 0 ]]; then
        dcs logs --tail 200 $follow_flag "$@"
    else
        dcs logs --tail 200 $follow_flag
    fi
}

cmd_status() {
    echo "== staging containers =="
    dcs ps
    echo
    echo "== last-deployed ref =="
    if git rev-parse --verify --quiet staging-current >/dev/null 2>&1; then
        printf "branch: staging-current → %s\n" "$(git rev-parse --short staging-current)"
        git log -1 --pretty=format:"  %h %s (%cr)" staging-current
        echo
    else
        echo "  (no staging-current branch yet — run: tools/stage deploy <ref>)"
    fi
}

cmd_wait_tunnel() {
    echo "→ waiting for cloudflared-staging to register all 4 connections..."
    local elapsed=0
    local timeout=60
    while (( elapsed < timeout )); do
        if dcs logs --tail 100 "$STAGING_TUNNEL_SERVICE" 2>/dev/null | grep -q "connIndex=3"; then
            echo "tunnel ready (4 connections registered)"
            return 0
        fi
        sleep 2
        elapsed=$((elapsed + 2))
        printf "."
    done
    echo
    err "tunnel did not register all 4 connections within ${timeout}s"
    err "check: tools/stage logs $STAGING_TUNNEL_SERVICE"
    return 1
}

cmd_smoke() {
    require_env_file

    # v1.7.2 Sprint 6: `--skip-device-flow` skips the device-flow
    # smoke (HMAC POST/PUT/GET via stra2us synth-traffic). Useful from
    # a container host that doesn't have python/venv set up. Other
    # flags pass through to smoke_test.sh untouched.
    local skip_device_flow=0
    local hostname_args=()
    for a in "$@"; do
        case "$a" in
            --skip-device-flow) skip_device_flow=1 ;;
            *)                  hostname_args+=("$a") ;;
        esac
    done

    echo "→ running smoke test against staging hostnames"
    # `set -a` auto-exports anything sourced; isolated to a subshell.
    # Reminder: device-host checks don't work reliably from the
    # container host itself (Synology hairpin NAT / loopback issue) —
    # pass --skip-device when running on the host, or run smoke from
    # a LAN dev box. See TODO.md and the smoke_test.sh header.
    (
        set -a
        source "$STAGING_ENV_FILE"
        STRA2US_BROWSER_HOST="$STAGING_BROWSER_HOST" \
        STRA2US_DEVICE_HOST="$STAGING_DEVICE_HOST" \
        STRA2US_DEVICE_PORT="$STAGING_DEVICE_PORT" \
        "$REPO_ROOT/tools/smoke_test.sh" "${hostname_args[@]}"
    )
    local hostname_rc=$?

    local device_rc=0
    if (( skip_device_flow )); then
        echo
        echo "→ device-flow smoke skipped (--skip-device-flow)"
    else
        echo
        cmd_smoke_device
        device_rc=$?
    fi

    return $(( hostname_rc | device_rc ))
}

# v1.7.2 Sprint 6: HMAC device-protocol smoke. Auto-provisions the
# smoke-test device on first run (subsequent runs are no-ops — the
# Redis SET is idempotent and the existing secret is reused).
cmd_smoke_device() {
    require_env_file

    # Ensure the smoke device is provisioned and fetch its secret in
    # one shot. `_ensure_smoke_device` prints to stderr; secret comes
    # back on stdout. Note `force=0` here — the only way to regenerate
    # the secret is the explicit `seed-smoke-device --force` path so a
    # routine `tools/stage smoke` never rotates secrets out from under
    # a running soak.
    echo "→ ensuring smoke-test device is provisioned"
    local secret
    secret=$(_ensure_smoke_device 0)
    if [[ -z "$secret" ]]; then
        err "failed to obtain smoke-device secret — see container logs"
        return 1
    fi

    echo
    # Run the device-flow checks in an isolated subshell so the export
    # of STRA2US_SECRET_HEX doesn't leak into the operator's parent
    # shell. The Python CLI reads the host/client_id/secret from env
    # (`tools/stra2us_cli/config.py:resolve`), so this is the
    # one-and-only credential plumbing needed.
    (
        STRA2US_HOST="http://${STAGING_DEVICE_HOST}:${STAGING_DEVICE_PORT}" \
        STRA2US_CLIENT_ID="$SMOKE_DEVICE_CLIENT_ID" \
        STRA2US_SECRET_HEX="$secret" \
        STRA2US_SMOKE_APP="$SMOKE_DEVICE_APP" \
        "$REPO_ROOT/tools/smoke_test_device.sh"
    )
}

# v1.7.2 Sprint 6: standalone provisioning entry point. Useful for
# re-seeding after a `tools/stage nuke` (filed for later) or rotating
# the secret if it's suspected to have leaked.
cmd_seed_smoke_device() {
    require_env_file
    local force=0
    if [[ "${1:-}" == "--force" ]]; then
        force=1
        echo "→ --force: regenerating smoke-device secret"
    else
        echo "→ ensuring smoke-test device is provisioned (idempotent)"
    fi
    local secret
    secret=$(_ensure_smoke_device "$force")
    if [[ -z "$secret" ]]; then
        die "failed to provision smoke device — see container logs"
    fi
    echo
    echo "smoke device ready: client_id=${SMOKE_DEVICE_CLIENT_ID}, app=${SMOKE_DEVICE_APP}"
    echo "(secret kept in Redis; not echoed. Run 'tools/stage smoke-device' to use.)"
}

cmd_smoke_prod() {
    # Source the deploy config to find $PROD_DIR. Same file used by
    # bootstrap-host.sh, sync-secrets.sh, and cmd_promote.
    local config_file="$REPO_ROOT/tools/.deploy-config"
    [[ -f "$config_file" ]] || die "$config_file missing — populate from tools/.deploy-config.example"
    # shellcheck disable=SC1090
    source "$config_file"
    [[ -n "${PROD_DIR:-}" ]] || die "PROD_DIR not set in $config_file"
    [[ -f "$PROD_DIR/.env" ]] || die "$PROD_DIR/.env missing — run tools/sync-secrets.sh first"

    echo "→ running smoke test against prod hostnames"
    # smoke_test.sh defaults match prod (BROWSER_HOST=stra2us.austindavid.com,
    # DEVICE_HOST=iot.stra2us.austindavid.com, port 8153) — no hostname
    # overrides needed; we only need the prod env so SMOKE_ADMIN_USER/PASS
    # (if present) get picked up for the activity-log + security_warnings
    # checks. Forwards extra args to smoke_test.sh (e.g. --skip-device).
    (
        set -a
        source "$PROD_DIR/.env"
        "$REPO_ROOT/tools/smoke_test.sh" "$@"
    )
}

cmd_deploy() {
    require_env_file
    local ref="${1:-}"

    if [[ -n "$ref" ]]; then
        echo "→ git fetch && checkout -B staging-current $ref"
        git fetch
        git checkout -B staging-current "$ref"
    else
        ref="$(git rev-parse --abbrev-ref HEAD)"
        echo "→ git pull on current branch ($ref)"
        git pull --ff-only
    fi

    # v1.7.1 Sprint 2: write the running-release tag so the admin
    # sidebar's version badge reflects what's actually deployed.
    # Done after the checkout so the SHA matches the new tree.
    _write_version_file "$ref" "."

    echo
    echo "→ rebuilding image and restarting stack"
    dcs up -d --build

    echo
    cmd_wait_tunnel || return 1

    echo
    echo "==================================================================="
    echo "Deploy complete."
    echo "  ref:       $(git rev-parse --abbrev-ref HEAD) @ $(git rev-parse --short HEAD)"
    echo "  containers up: $(dcs ps --services 2>/dev/null | tr '\n' ' ')"
    echo "==================================================================="
    echo
    read -rp "Press <Enter> to run a live smoke test (Ctrl-C to skip)... " _
    echo
    cmd_smoke
}

cmd_promote() {
    local tag="${1:-}"
    if [[ -z "$tag" ]]; then
        die "usage: tools/stage promote <tag>  (e.g. v1.5.2)"
    fi

    # Source the deploy config to find $PROD_DIR. Same file used by
    # bootstrap-host.sh and sync-secrets.sh.
    local config_file="$REPO_ROOT/tools/.deploy-config"
    [[ -f "$config_file" ]] || die "$config_file missing — run from a host with a populated tools/.deploy-config"
    # shellcheck disable=SC1090
    source "$config_file"
    [[ -n "${PROD_DIR:-}" ]] || die "PROD_DIR not set in $config_file"
    [[ -d "$PROD_DIR" ]] || die "PROD_DIR ($PROD_DIR) doesn't exist on this host"
    [[ -f "$PROD_DIR/.env" ]] || die "$PROD_DIR/.env missing — run tools/sync-secrets.sh first"

    echo "→ fetching tags in $PROD_DIR"
    git -C "$PROD_DIR" fetch --tags

    if ! git -C "$PROD_DIR" rev-parse --verify --quiet "refs/tags/$tag" >/dev/null; then
        die "tag '$tag' not found after fetch — was it pushed to origin?"
    fi

    # Warn if the tag's commit isn't on staging-current. Trust-but-warn
    # per docs/staging_environment.md "Decisions made → Promote".
    local staging_head
    staging_head=$(git -C "$REPO_ROOT" rev-parse --verify --quiet staging-current 2>/dev/null || true)
    local tag_commit
    tag_commit=$(git -C "$PROD_DIR" rev-parse "$tag^{commit}")
    if [[ -n "$staging_head" && "$staging_head" != "$tag_commit" ]]; then
        echo
        echo "WARNING: tag $tag (commit $(git -C "$PROD_DIR" rev-parse --short "$tag"))"
        echo "         does not match staging-current ($(git -C "$REPO_ROOT" rev-parse --short staging-current))."
        echo "         You may be promoting code that wasn't verified on staging."
        if [[ "${2:-}" != "--yes" ]]; then
            read -rp "Continue anyway? [y/N] " confirm
            case "$confirm" in
                y|Y) ;;
                *) echo "aborted"; exit 1 ;;
            esac
        fi
    fi

    echo
    echo "→ checkout -B deploy $tag in $PROD_DIR"
    git -C "$PROD_DIR" checkout -B deploy "$tag"

    # v1.7.1 Sprint 2: write the running-release tag to the prod
    # clone's backend/VERSION. Backend reads it on container start;
    # admin badge surfaces it. Done after the checkout so the SHA
    # matches the tagged tree.
    _write_version_file "$tag" "$PROD_DIR"

    echo
    echo "→ docker compose build + up (prod). With bind-mounted backend,"
    echo "  Python code applies on restart; --build catches any image"
    echo "  layer changes (Dockerfile, requirements.txt)."
    docker compose \
        --env-file "$PROD_DIR/.env" \
        -f "$PROD_DIR/docker-compose.yaml" \
        -p stra2us-prod \
        up -d --build

    echo
    echo "→ waiting for cloudflared (prod) to register all 4 connections..."
    local elapsed=0
    while (( elapsed < 60 )); do
        if docker compose -p stra2us-prod logs --tail 100 cloudflared 2>/dev/null | grep -q "connIndex=3"; then
            echo "  tunnel ready"
            break
        fi
        sleep 2
        elapsed=$((elapsed + 2))
        printf "."
    done
    if (( elapsed >= 60 )); then
        echo
        echo "WARNING: tunnel did not register all 4 connections within 60s"
        echo "         Check: docker compose -p stra2us-prod logs cloudflared"
    fi

    local prod_services
    prod_services=$(docker compose -p stra2us-prod ps --services 2>/dev/null | tr '\n' ' ')
    echo
    echo "==================================================================="
    echo "Prod promoted to $tag."
    echo "  prod dir:      $PROD_DIR"
    echo "  deploy branch: $(git -C "$PROD_DIR" rev-parse --abbrev-ref HEAD) @ $(git -C "$PROD_DIR" rev-parse --short HEAD)"
    echo "  containers up: $prod_services"
    echo "==================================================================="
    echo
    read -rp "Press <Enter> to run a live smoke test against prod (Ctrl-C to skip)... " _
    echo
    cmd_smoke_prod
    echo
    echo "After smoke, eyeball: https://stra2us.austindavid.com/admin/"
    echo
    echo "Rollback (if needed):"
    echo "    docker tag stra2us-stra2us-iot:pre-${tag} \\"
    echo "        stra2us-stra2us-iot:latest"
    echo "    docker compose -p stra2us-prod up -d"
    echo "    (only works if you tagged the previous image before promote)"
}

cmd_seed_users() {
    require_env_file

    local force=0
    if [[ "${1:-}" == "--force" ]]; then
        force=1
        echo "→ --force: re-provisioning all users regardless of existing state"
    else
        echo "→ seeding staging users (idempotent — skip if already provisioned;"
        echo "   pass --force to re-provision and overwrite)"
    fi

    # smoke user is read-only (the smoke test never mutates state).
    # admin (rescue) + OAuth operator are read-write (full operator
    # capabilities). Tighter smoke ACL limits blast radius if
    # SMOKE_ADMIN_PASS ever leaks (it lives in .env files on dev,
    # host, and possibly CI — leak surface is broader than rw users).
    local _wildcard_r='{"permissions":[{"prefix":"*","access":"r"}]}'
    local _wildcard_rw='{"permissions":[{"prefix":"*","access":"rw"}]}'

    # SMOKE user — htpasswd + read-only wildcard ACL.
    if (( !force )) && htpasswd_has_user smoke && redis_has_acl smoke; then
        echo "  ✓ smoke already provisioned (htpasswd + ACL); skipping"
    else
        local smoke_pass
        if grep -q '^SMOKE_ADMIN_PASS=' "$STAGING_ENV_FILE"; then
            smoke_pass=$(grep '^SMOKE_ADMIN_PASS=' "$STAGING_ENV_FILE" | cut -d= -f2- | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//")
        else
            read -rsp "Password for staging 'smoke' user: " smoke_pass; echo
        fi
        (cd "$REPO_ROOT/backend" && python3 create_admin.py smoke "$smoke_pass")
        dcs exec -T "$STAGING_BACKEND_SERVICE" redis-cli SET \
            'admin_acls:smoke' "$_wildcard_r"
        echo "  ✓ smoke provisioned (read-only)"
    fi

    # ADMIN user — htpasswd + wildcard rw. Rescue-style operator path
    # on iot-staging (htpasswd is reachable on the device hostname even
    # when OAuth is the primary path on the browser hostname).
    if (( !force )) && htpasswd_has_user admin && redis_has_acl admin; then
        echo "  ✓ admin already provisioned (htpasswd + ACL); skipping"
    else
        local admin_pass
        read -rsp "Password for staging 'admin' user (rescue path): " admin_pass; echo
        (cd "$REPO_ROOT/backend" && python3 create_admin.py admin "$admin_pass")
        dcs exec -T "$STAGING_BACKEND_SERVICE" redis-cli SET \
            'admin_acls:admin' "$_wildcard_rw"
        echo "  ✓ admin provisioned"
    fi

    # OAUTH user — wildcard rw (auth comes from Google). We have
    # to ask for the email before we can check; blank input skips.
    local oauth_email
    read -rp "Google email for staging OAuth user (blank to skip): " oauth_email
    if [[ -z "$oauth_email" ]]; then
        echo "  → skipping OAuth user (none specified)"
    elif (( !force )) && redis_has_acl "$oauth_email"; then
        echo "  ✓ $oauth_email already provisioned (ACL); skipping"
    else
        dcs exec -T "$STAGING_BACKEND_SERVICE" redis-cli SET \
            "admin_acls:$oauth_email" "$_wildcard_rw"
        echo "  ✓ $oauth_email provisioned"
    fi

    echo
    echo "Done."
}

# --- dispatch --------------------------------------------------------

[[ $# -ge 1 ]] || { cmd_help; exit 1; }

case "$1" in
    up)            shift; cmd_up "$@" ;;
    down)          shift; cmd_down "$@" ;;
    bash)          shift; cmd_bash "$@" ;;
    logs)          shift; cmd_logs "$@" ;;
    status)        shift; cmd_status "$@" ;;
    wait-tunnel)   shift; cmd_wait_tunnel "$@" ;;
    smoke)              shift; cmd_smoke "$@" ;;
    smoke-device)       shift; cmd_smoke_device "$@" ;;
